{
  "manifest_version": 3,
  "name": "ChatGPT侧边目录导航栏",
  "version": "91.78",
  "description": "ChatGPT:侧边目录/书签/搜索/导出。弱引用/限量渲染，性能优秀。",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["detect-navigation.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
